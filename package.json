{
  "name": "grome-connect",
  "version": "0.2.5",
  "description": "CLI for connected workspaces — link projects, share context with AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "grome": "bin/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "workspace",
    "connected",
    "context"
  ],
  "license": "MIT",
  "author": "Ronald Lee <leeronalda@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getgrome/grome-connect.git"
  },
  "bugs": {
    "url": "https://github.com/getgrome/grome-connect/issues"
  },
  "homepage": "https://github.com/getgrome/grome-connect#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
